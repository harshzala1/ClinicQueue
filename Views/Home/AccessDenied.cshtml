@{
    ViewData["Title"] = "Access Denied";
}

<div class="animate-fadeIn" style="min-height:60vh; display:flex; align-items:center; justify-content:center;">
    <div class="text-center">
        <div style="font-size:5rem; color:#ef4444; margin-bottom:1rem;">
            <i class="fas fa-shield-alt"></i>
        </div>
        <h1 style="font-size:2rem; font-weight:800; color:var(--text-primary);">403 — Access Denied</h1>
        <p class="text-muted mt-2 mb-4">You do not have permission to access this page.</p>
        <a href="@Url.Action("Index", "Home")" class="btn btn-primary" style="border-radius:10px; background:var(--accent-gradient); border:none; font-weight:600;">
            <i class="fas fa-home me-1"></i>Go to Dashboard
        </a>
    </div>
</div>
