@model ClinicQueue.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="animate-fadeIn">
    <!-- Page Header -->
    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1><i class="fas fa-tachometer-alt me-2" style="color:var(--accent);"></i>Admin Dashboard</h1>
            <p>Manage your clinic users and view clinic information</p>
        </div>
        <button class="btn btn-primary" style="border-radius:10px; background:var(--accent-gradient); border:none; padding:.6rem 1.2rem; font-weight:600;"
                data-bs-toggle="modal" data-bs-target="#createUserModal">
            <i class="fas fa-user-plus me-1"></i>Add User
        </button>
    </div>

    <!-- Stat Cards -->
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card purple">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-value">@(Model.Clinic?.Name ?? "—")</div>
                        <div class="stat-label">Clinic Name</div>
                    </div>
                    <div class="stat-icon purple"><i class="fas fa-hospital"></i></div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card green">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-value">@(Model.Clinic?.UserCount ?? 0)</div>
                        <div class="stat-label">Total Users</div>
                    </div>
                    <div class="stat-icon green"><i class="fas fa-users"></i></div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card blue">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-value">@(Model.Clinic?.AppointmentCount ?? 0)</div>
                        <div class="stat-label">Appointments</div>
                    </div>
                    <div class="stat-icon blue"><i class="fas fa-calendar-check"></i></div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card orange">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-value">@(Model.Clinic?.Code ?? "—")</div>
                        <div class="stat-label">Clinic Code</div>
                    </div>
                    <div class="stat-icon orange"><i class="fas fa-hashtag"></i></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Users Table -->
    <div class="table-card card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span><i class="fas fa-users me-2"></i>Clinic Users (@Model.Users.Count)</span>
            <input type="text" id="userSearch" class="search-input" placeholder="Search users..."
                   onkeyup="filterTable('userSearch','usersTable')" />
        </div>
        <div class="card-body p-0">
            @if (Model.Users.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover" id="usersTable">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Phone</th>
                                <th>Created</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int idx = 1; }
                            @foreach (var user in Model.Users)
                            {
                                <tr>
                                    <td class="fw-semibold text-muted">@(idx++)</td>
                                    <td class="fw-semibold">@user.Name</td>
                                    <td>@user.Email</td>
                                    <td>
                                        <span class="badge @GetRoleBadgeClass(user.Role)">
                                            @user.Role.ToUpper()
                                        </span>
                                    </td>
                                    <td>@(user.Phone ?? "—")</td>
                                    <td class="text-muted">@(user.CreatedAt?.ToString("MMM dd, yyyy") ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-users-slash d-block"></i>
                    <h5>No Users Found</h5>
                    <p>Create your first clinic user by clicking "Add User" above.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Create User Modal -->
<div class="modal fade" id="createUserModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-user-plus me-2"></i>Create New User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateUser" asp-controller="Admin" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input type="text" name="Name" class="form-control" required minlength="3" placeholder="Full name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="Email" class="form-control" required placeholder="user@example.com" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="Password" class="form-control" required minlength="6" placeholder="Min 6 characters" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role</label>
                        <select name="Role" class="form-select" required>
                            <option value="">Select role...</option>
                            <option value="doctor">Doctor</option>
                            <option value="receptionist">Receptionist</option>
                            <option value="patient">Patient</option>
                        </select>
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Phone <span class="text-muted">(optional)</span></label>
                        <input type="text" name="Phone" class="form-control" placeholder="+91 XXXXX XXXXX" />
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" style="background:var(--accent-gradient); border:none; border-radius:10px; font-weight:600;">
                        <i class="fas fa-check me-1"></i>Create User
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    string GetRoleBadgeClass(string? role) => (role?.ToLower()) switch
    {
        "admin" => "bg-primary",
        "doctor" => "bg-success",
        "receptionist" => "bg-info text-dark",
        "patient" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}
